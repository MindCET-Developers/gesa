# Copy to .env.local and fill in. None are required to run the site with seed
# content — they activate the newsletter and (later) the Sanity CMS.

# --- Site / marketing ------------------------------------------------------
# Canonical origin for metadata, sitemap, robots and structured data.
# NEXT_PUBLIC_* values are inlined at build time — set them in Vercel too.
NEXT_PUBLIC_SITE_URL=https://www.gesawards.io
# Google Analytics 4 measurement ID (falls back to the production property).
NEXT_PUBLIC_GA_ID=G-4JBT3Y2KMR
# Google Ads conversion account (AW-XXXXXXXXXX). Leave empty until a campaign
# runs — the Ads tag is only rendered when this is set.
NEXT_PUBLIC_GOOGLE_ADS_ID=

# --- Newsletter (Resend Audiences) ---------------------------------------
# Create a key at https://resend.com/api-keys and an audience at
# https://resend.com/audiences. Without these the signup succeeds locally
# (dev mode) but stores nothing.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# --- Sanity CMS (optional, for go-live) ----------------------------------
# Set after running `sanity init`. See docs/CMS-SETUP.md.
NEXT_PUBLIC_SANITY_PROJECT_ID=g5zdluvf
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
